{
  "name": "ontonim-ai",
  "displayName": "Ontonim AI",
  "description": "An agentic AI coding assistant that can read, write, edit, and search files inside your workspace.",
  "version": "0.1.0",
  "publisher": "RashedulHaqueRasel1",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/RashedulHaqueRasel1/ontonim-ai.git"
  },
  "homepage": "https://github.com/RashedulHaqueRasel1/ontonim-ai#readme",
  "bugs": {
    "url": "https://github.com/RashedulHaqueRasel1/ontonim-ai/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Linters"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "ontonim-ai-sidebar",
          "title": "Ontonim AI",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ontonim-ai-sidebar": [
        {
          "type": "webview",
          "id": "ontonim-ai.chatView",
          "name": "Ontonim AI Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "ontonim-ai.focusSidebar",
        "title": "Ontonim AI: Focus Chat Panel",
        "icon": "resources/icon.svg"
      },
      {
        "command": "ontonim-ai.setApiKey",
        "title": "Ontonim AI: Set API Key"
      },
      {
        "command": "ontonim-ai.clearApiKey",
        "title": "Ontonim AI: Clear API Key"
      },
      {
        "command": "ontonim-ai.logout",
        "title": "Ontonim AI: Logout"
      },
      {
        "command": "ontonim-ai.explainAndFix",
        "title": "Ontonim AI: Explain and Fix Error"
      },
      {
        "command": "ontonim-ai.refreshWorkspaceState",
        "title": "Ontonim AI: Refresh Workspace Intelligence"
      },
      {
        "command": "ontonim-ai",
        "title": "Ontonim AI"
      }
    ],
    "keybindings": [
      {
        "command": "ontonim-ai.explainAndFix",
        "key": "ctrl+shift+.",
        "when": "editorHasDiagnostics && editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ontonim-ai.focusSidebar",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "ontonim-ai.refreshWorkspaceState",
          "group": "navigation",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Ontonim AI",
      "properties": {
        "ontonimAi.defaultModel": {
          "type": "string",
          "default": "google/gemini-2.5-flash",
          "description": "Default model to use for Ontonim AI conversations.",
          "enum": [
            "google/gemini-2.5-flash",
            "google/gemini-2.5-pro",
            "anthropic/claude-3.5-sonnet",
            "meta-llama/llama-3.3-70b-instruct",
            "deepseek/deepseek-chat",
            "llama-3.3-70b-versatile",
            "llama-3.1-8b-instant",
            "gemma2-9b-it",
            "deepseek-r1-distill-llama-70b",
            "qwen/qwen3-32b"
          ]
        },
        "ontonimAi.autoApproveTools": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run read-only tools without prompting for user approval."
        },
        "ontonimAi.backendUrl": {
          "type": "string",
          "default": "http://localhost:3987",
          "description": "Backend URL used for Google login and user profile sync."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "backend:dev": "node backend/server.js",
    "backend:start": "node backend/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "eslint": "^9.39.3"
  }
}
